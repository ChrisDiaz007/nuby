<div class="pf sm:max-w-md sm:mx-auto">

  <%# HEADING %>
  <div class="pf-fu pf-d1" style="display:flex; align-items:center; gap:12px; margin-bottom:28px;">
    <%= link_to profile_path, style: "width:36px; height:36px; background:var(--card); border-radius:10px; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 8px var(--shadow); text-decoration:none; flex-shrink:0;" do %>
      <i class="fa-solid fa-arrow-left" style="color:var(--text); font-size:13px;"></i>
    <% end %>
    <div>
      <h1 style="font-size:20px; font-weight:800; color:var(--text); margin:0;">Edit Profile</h1>
      <p style="font-size:12px; color:var(--sub); margin:2px 0 0;">Update your name</p>
    </div>
  </div>

  <%# FORM CARD %>
  <div class="pf-card pf-fu pf-d2" style="padding:20px;">
    <%= form_with model: current_user, url: profile_path, method: :patch do |f| %>

      <div style="margin-bottom:16px;">
        <%= f.label :email, "Email", class: "pf-label" %>
        <%= f.email_field :email, class: "pf-input", disabled: true, placeholder: current_user.email %>
      </div>

      <div style="margin-bottom:16px;">
        <%= f.label :first_name, "First Name", class: "pf-label" %>
        <%= f.text_field :first_name, class: "pf-input" %>
      </div>

      <div style="margin-bottom:24px;">
        <%= f.label :last_name, "Last Name", class: "pf-label" %>
        <%= f.text_field :last_name, class: "pf-input" %>
      </div>

      <%= f.submit "Save Changes", class: "pf-btn-primary" %>

    <% end %>
  </div>

</div>
