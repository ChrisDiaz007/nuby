<div class="p-5 flex justify-center min-h-screen bg-gray-100">
  <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-indigo-300">Nuby</h1>
      <p class="text-gray-500 text-sm mt-1">Create your account and start tracking.</p>
    </div>
    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="flex-1">
            <%= f.input :first_name,
                required: true,
                autofocus: true,
                label_html: { class: "block text-sm font-medium text-gray-700 mb-1" },
                input_html: { class: "w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-transparent" } %>
          </div>
          <div class="flex-1">
            <%= f.input :last_name,
                required: true,
                label_html: { class: "block text-sm font-medium text-gray-700 mb-1" },
                input_html: { class: "w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-transparent" } %>
          </div>
        </div>
        <%= f.input :email,
            required: true,
            input_html: { autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-transparent" },
            label_html: { class: "block text-sm font-medium text-gray-700 mb-1" } %>
        <%= f.input :password,
            required: true,
            hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
            input_html: { autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-transparent" },
            label_html: { class: "block text-sm font-medium text-gray-700 mb-1" } %>
        <%= f.input :password_confirmation,
            required: true,
            input_html: { autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-transparent" },
            label_html: { class: "block text-sm font-medium text-gray-700 mb-1" } %>
      </div>
      <div class="mt-6">
        <%= f.button :submit, "Sign up",
            class: "w-full bg-indigo-300 hover:bg-indigo-400 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 cursor-pointer" %>
      </div>
    <% end %>
    <div class="mt-6 text-center text-sm text-indigo-500 space-y-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
