<div class="w-full max-w-md px-6 py-10">
  <div class="bg-white rounded-2xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-green-700">Nuvy</h1>
      <p class="text-gray-500 text-sm mt-1">Welcome back! Log in to track your nutrition.</p>
    </div>
    <% if flash[:alert] %>
      <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-6 text-sm text-red-600 text-center">
        Incorrect email or password. Please try again.
      </div>
    <% end %>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-5">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" %>
      </div>
      <div class="mb-5">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" %>
      </div>
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-5">
          <%= f.check_box :remember_me, class: "h-4 w-4 text-green-600 border-gray-300 rounded" %>
          <%= f.label :remember_me, class: "ml-2 text-sm text-gray-600" %>
        </div>
      <% end %>
      <%= f.submit "Log in", class: "w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 cursor-pointer" %>
    <% end %>
    <div class="mt-6 text-center text-sm text-gray-500 space-y-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
