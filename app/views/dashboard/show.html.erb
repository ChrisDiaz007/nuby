  
<div class="container mx-auto px-4 py-8 max-w-2xl">
  <h1 class="text-2xl font-bold mb-6">My Activity</h1>
  <%# Weekly chart %>
  <h2 class="text-lg font-semibold mb-3">Tracking Stats</h2>
  <div class="mb-8">
    <canvas id="weeklyChart" height="120"></canvas>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  const ctx = document.getElementById('weeklyChart').getContext('2d');
  const dailyTarget = <%= @daily_target %>;
  const data = <%= raw @weekly_data.to_json %>;

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: data.map(d => d.date),
      datasets: [{
        label: 'Calories',
        data: data.map(d => d.calories),
        backgroundColor: data.map(d => d.calories > dailyTarget ? '#ef4444' : '#84cc16')
      }]
    },
    options: {
      plugins: {
        legend: { display: false }
      },
      scales: { y: { beginAtZero: true } }
    }
  });
</script>
