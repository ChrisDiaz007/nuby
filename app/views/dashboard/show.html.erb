  
<div class="container mx-auto px-4 py-8 max-w-2xl">
  <h1 class="text-2xl font-bold mb-6">Today's Meals</h1>
  <% if @today_logs.empty? %>
    <p class="text-gray-500 mb-6">No meals logged today. <%= link_to "Go to your saved foods", user_foods_path, class: "text-lime-600
  underline" %> to log one.</p>
  <% else %>
    <% ["breakfast", "lunch", "dinner"].each do |meal| %>
      <% next if @meals[meal].blank? %>
      <div class="mb-6">
        <h2 class="text-lg font-semibold capitalize mb-2"><%= meal %></h2>
        <div class="border rounded-lg divide-y">
          <% @meals[meal].each do |log| %>
            <div class="flex justify-between items-center px-4 py-3">
              <div>
                <p class="font-medium"><%= log.food.name %></p>
                <p class="text-sm text-gray-500"><%= log.servings %> serving(s)</p>
              </div>
              <div class="flex items-center gap-4">
                <p class="text-sm"><%= ((log.food.calories_per_100g || 0) * log.servings / 100).round %> kcal</p>
                <%= button_to "✕", food_log_path(log), method: :delete, class: "text-red-400 hover:text-red-600 text-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    <div class="text-right font-bold text-lg mt-4">
      Total: <%= @total_calories.round %> kcal
    </div>
  <% end %>
</div>
