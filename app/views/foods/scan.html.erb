<div class="fd">
  <div class="fd-scan-wrap sm:max-w-md sm:mx-auto" data-controller="barcode-scanner">

    <h1 style="font-size:22px; font-weight:800; color:var(--text); margin:0 0 6px;">Scan a Barcode</h1>
    <p style="font-size:12px; color:var(--sub); margin:0 0 24px; font-weight:600;">Use your camera or enter manually</p>

    <%# Camera preview %>
    <div data-barcode-scanner-target="preview" class="hidden fd-camera-box"></div>

    <%# Start button %>
    <button data-barcode-scanner-target="startBtn"
      data-action="click->barcode-scanner#start"
      class="fd-btn-primary" style="margin-bottom:10px;">
      <i class="fa-solid fa-camera"></i> Scan with Camera
    </button>

    <%# Stop button %>
    <button data-barcode-scanner-target="stopBtn"
      data-action="click->barcode-scanner#stop"
      class="fd-btn-outline hidden" style="margin-bottom:10px;">
      <i class="fa-solid fa-stop"></i> Stop Camera
    </button>

    <div class="fd-divider">or enter manually</div>

    <%= form_with url: lookup_foods_path, method: :post, data: { barcode_scanner_target: "form" } do |f| %>
      <div style="margin-bottom:14px;">
        <%= f.label :barcode, "Barcode Number", class: "fd-label" %>
        <%= f.text_field :barcode, class: "fd-input", placeholder: "e.g. 0016000275287",
            data: { barcode_scanner_target: "input" } %>
      </div>
      <%= f.submit "Look Up", class: "fd-btn-primary", style: "border:none; cursor:pointer;" %>
    <% end %>

  </div>
</div>
