<div data-controller="nutrition-row">
  <button data-action="click->nutrition-row#toggle" class="w-full flex items-center gap-3 px-4 py-3 hover:bg-gray-50 border-t">
    <div class="flex-1 text-left">
      <p class="font-medium text-sm"><%= label %></p>
      <p class="text-xs text-gray-400"><%= subtitle %></p>
    </div>
    <span class="text-sm font-semibold mr-2"><%= value %></span>
    <% if amount.nil?
         dot_color = "bg-gray-300"
       elsif negative
         dot_color = amount.to_f > (max * 0.7) ? "bg-red-500" : amount.to_f > (max * 0.4) ? "bg-orange-400" : "bg-yellow-400"
       else
         dot_color = amount.to_f > (max * 0.5) ? "bg-green-500" : amount.to_f > (max * 0.2) ? "bg-yellow-400" : "bg-red-500"
       end %>
    <span class="<%= dot_color %> w-3 h-3 rounded-full"></span>
    <i class="fa-solid fa-chevron-down text-gray-400 text-xs transition-transform" data-nutrition-row-target="arrow"></i>
  </button>
  <div class="hidden px-4 pb-4 bg-gray-50" data-nutrition-row-target="content">
    <% percentage = amount.nil? ? 0 : [(amount.to_f / max * 100).round, 100].min %>
    <div class="relative h-3 rounded-full overflow-hidden mt-2" style="background: <%= negative ? 'linear-gradient(to right, #22c55e, #facc15, #ef4444)' : 'linear-gradient(to right, #ef4444, #facc15, #22c55e)' %>">
      <div class="absolute top-0 bottom-0 w-0.5 bg-black opacity-70" style="left: <%= percentage %>%"></div>
    </div>
    <div class="flex justify-between text-xs text-gray-400 mt-1">
      <span>0</span>
      <span><%= max %></span>
    </div>
  </div>
</div>
