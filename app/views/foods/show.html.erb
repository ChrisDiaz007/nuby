<div class="fd sm:max-w-md sm:mx-auto">

  <%# PRODUCT HEADER %>
  <div class="fd-card" style="padding:18px 18px 20px; display:flex; gap:14px; align-items:flex-start;">
    <% if @food.image_url.present? %>
      <%= image_tag @food.image_url, style: "width:72px; height:72px; border-radius:16px; object-fit:contain; background:var(--bg); flex-shrink:0; border:1px solid var(--border);" %>
    <% else %>
      <div style="width:72px; height:72px; border-radius:16px; background:var(--bg); display:flex; align-items:center; justify-content:center; flex-shrink:0; border:1px solid var(--border);">
        <i class="fa-solid fa-image" style="color:var(--sub); font-size:22px;"></i>
      </div>
    <% end %>
    <div style="flex:1; min-width:0;">
      <h1 style="font-size:16px; font-weight:800; color:var(--text); margin:0 0 3px; line-height:1.3;"><%= @food.name %></h1>
      <p style="font-size:12px; color:var(--sub); margin:0 0 10px; font-weight:600;"><%= @food.brand %></p>
      <div style="display:flex; align-items:center; gap:8px;">
        <% score = @food.nutri_score&.upcase || "?" %>
        <% bg = case @food.nutri_score&.downcase
                when "a" then "#1B7C3A"
                when "b" then "#5CBE3B"
                when "c" then "#F59E0B"
                when "d" then "#F97316"
                when "e" then "#EF4444"
                else "#9CA3AF" end %>
        <span style="background:<%= bg %>; color:#fff; font-size:12px; font-weight:800; padding:4px 12px; border-radius:99px; letter-spacing:0.04em;">
          Nutri-Score <%= score %>
        </span>
        <% if @food.nutriscore_score.present? %>
          <span style="font-size:12px; color:var(--sub); font-weight:600;"><%= @food.nutriscore_score %>/100</span>
        <% end %>
      </div>
    </div>
  </div>

  <%# NEGATIVE SECTION %>
  <div class="fd-card">
    <p class="fd-section-title">Negative</p>

    <%# Additives — custom row with Stimulus %>
    <div data-controller="nutrition-row">
      <button data-action="click->nutrition-row#toggle" class="nr-btn">
        <div style="width:32px; height:32px; background:#FFF3E0; border-radius:9px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
          <i class="fa-solid fa-flask" style="color:#FB8C00; font-size:12px;"></i>
        </div>
        <div style="flex:1; text-align:left;">
          <p style="font-size:13px; font-weight:700; color:var(--text); margin:0;">Additives</p>
          <p style="font-size:11px; color:var(--sub); margin:2px 0 0;">Contains additives</p>
        </div>
        <span style="font-size:13px; font-weight:700; color:var(--text); margin-right:8px;"><%= @food.additives_count || 0 %></span>
        <span class="nr-dot" style="background:<%= (@food.additives_count || 0) > 5 ? '#EF4444' : (@food.additives_count || 0) > 2 ? '#F97316' : '#F59E0B' %>;"></span>
        <i class="fa-solid fa-chevron-down" style="color:var(--sub); font-size:11px; margin-left:8px; transition:transform 0.2s;" data-nutrition-row-target="arrow"></i>
      </button>
      <div class="hidden nr-content" data-nutrition-row-target="content">
        <% if (@food.additives_count || 0) == 0 %>
          <p style="font-size:13px; color:var(--green-dk); font-weight:600; display:flex; align-items:center; gap:6px; padding-top:12px;">
            <i class="fa-solid fa-circle-check"></i> No additives
          </p>
        <% elsif (@food.additives_count || 0) <= 2 %>
          <p style="font-size:13px; color:#F59E0B; font-weight:600; display:flex; align-items:center; gap:6px; padding-top:12px; margin-bottom:8px;">
            <i class="fa-solid fa-circle-exclamation"></i> Low risk additives
          </p>
          <%= link_to additives_food_path(@food), style: "font-size:12px; color:var(--green); font-weight:700; text-decoration:none;" do %>
            <i class="fa-solid fa-circle-info"></i> View additive details
          <% end %>
        <% else %>
          <p style="font-size:13px; color:#EF4444; font-weight:600; display:flex; align-items:center; gap:6px; padding-top:12px; margin-bottom:8px;">
            <i class="fa-solid fa-triangle-exclamation"></i> Contains multiple additives
          </p>
          <%= link_to additives_food_path(@food), style: "font-size:12px; color:var(--green); font-weight:700; text-decoration:none;" do %>
            <i class="fa-solid fa-circle-info"></i> View additive details
          <% end %>
        <% end %>
      </div>
    </div>

    <%= render "nutrition_row", label: "Energy",        subtitle: "Limit it · per 100g", value: "#{@food.calories_per_100g&.round} kcal",  amount: @food.calories_per_100g,  max: 800,  negative: true,  icon: "fa-bolt",        icon_bg: "#FFF3E0", icon_color: "#FB8C00" %>
    <%= render "nutrition_row", label: "Sugar",         subtitle: "Avoid it · per 100g", value: "#{@food.sugars_100g&.round(1)}g",            amount: @food.sugars_100g,        max: 45,   negative: true,  icon: "fa-candy-cane",  icon_bg: "#FCE4EC", icon_color: "#E91E63" %>
    <%= render "nutrition_row", label: "Saturated Fat", subtitle: "Avoid it · per 100g", value: "#{@food.saturated_fat_100g&.round(1)}g",     amount: @food.saturated_fat_100g, max: 10,   negative: true,  icon: "fa-droplet",     icon_bg: "#FFEBEE", icon_color: "#EF5350" %>
    <%= render "nutrition_row", label: "Salt",          subtitle: "Limit it · per 100g", value: "#{@food.salt_100g&.round(2)}g",              amount: @food.salt_100g,          max: 2.3,  negative: true,  icon: "fa-water",       icon_bg: "#E3F2FD", icon_color: "#1E88E5" %>
  </div>

  <%# POSITIVE SECTION %>
  <div class="fd-card">
    <p class="fd-section-title">Positive</p>
    <%= render "nutrition_row", label: "Fiber",                       subtitle: "Good quantity · per 100g", value: "#{@food.fiber_100g&.round(1)}g",      amount: @food.fiber_100g,      max: 9,   negative: false, icon: "fa-seedling",   icon_bg: "#E8F5E9", icon_color: "#43A047" %>
    <%= render "nutrition_row", label: "Fruits, Vegetables & Legumes", subtitle: "per 100g",             value: "#{@food.fruits_veg_100g&.round(1)}%",   amount: @food.fruits_veg_100g, max: 100, negative: false, icon: "fa-apple-whole", icon_bg: "#E8F5DE", icon_color: "#5CBE3B" %>
  </div>

  <%# NUTRITION FACTS %>
  <div class="fd-card">
    <p class="fd-section-title">Nutrition Facts</p>
    <div class="fd-fact-row">
      <span style="font-size:13px; font-weight:600; color:var(--text);">Fat</span>
      <span style="font-size:13px; font-weight:800; color:var(--text);"><%= @food.fat_100g&.round(1) %>g</span>
    </div>
    <div class="fd-fact-row">
      <span style="font-size:13px; font-weight:600; color:var(--text);">Carbohydrates</span>
      <span style="font-size:13px; font-weight:800; color:var(--text);"><%= @food.carbohydrates_100g&.round(1) %>g</span>
    </div>
    <div class="fd-fact-row">
      <span style="font-size:13px; font-weight:600; color:var(--text);">Protein</span>
      <span style="font-size:13px; font-weight:800; color:var(--text);"><%= @food.protein_100g&.round(1) %>g</span>
    </div>
  </div>

  <%# ACTIONS %>
  <div style="padding:16px 16px 0; display:flex; gap:10px;">
    <%= button_to "Add to My List", user_foods_path,
      params: { user_food: { food_id: @food.id } },
      class: "fd-btn-primary",
      style: "flex:1; border:none; cursor:pointer;" %>
    <%= link_to "Dismiss", scan_foods_path,
      class: "fd-btn-outline",
      style: "flex:1;" %>
  </div>

</div>
