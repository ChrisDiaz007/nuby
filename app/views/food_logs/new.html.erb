<div class="fd-page sm:max-w-md sm:mx-auto">

  <%# HEADER %>
  <div style="display:flex; align-items:center; gap:12px; margin-bottom:28px;">
    <%= link_to food_logs_path(meal_type: @meal_type, date: @date), class: "fd-back-btn" do %>
      <i class="fa-solid fa-arrow-left" style="color:var(--text); font-size:13px;"></i>
    <% end %>
    <div>
      <h1 style="font-size:20px; font-weight:800; color:var(--text); margin:0;">Add to <span style="text-transform:capitalize;"><%= @meal_type %></span></h1>
      <p style="font-size:12px; color:var(--sub); margin:2px 0 0; font-weight:600;"><%= Date.parse(@date.to_s).strftime("%A, %B %-d") %></p>
    </div>
  </div>

  <%# FOOD LIST %>
  <% if @user_foods.empty? %>
    <div style="background:var(--card); border-radius:18px; padding:28px; text-align:center; box-shadow:0 2px 10px var(--shadow);">
      <i class="fa-solid fa-barcode" style="color:var(--sub); font-size:28px; margin-bottom:10px; display:block;"></i>
      <p style="font-size:14px; font-weight:700; color:var(--sub); margin:0 0 4px;">No saved foods yet</p>
      <%= link_to scan_foods_path, style: "font-size:13px; color:var(--green); font-weight:700; text-decoration:none;" do %>
        Scan a barcode to add one <i class="fa-solid fa-arrow-right" style="font-size:11px;"></i>
      <% end %>
    </div>
  <% else %>
    <div>
      <% @user_foods.each do |user_food| %>
        <%= form_with url: food_logs_path, method: :post do |f| %>
          <%= f.hidden_field :food_id,   value: user_food.food.id,  name: "food_log[food_id]" %>
          <%= f.hidden_field :meal_type, value: @meal_type,         name: "food_log[meal_type]" %>
          <%= f.hidden_field :logged_on, value: @date,              name: "food_log[logged_on]" %>
          <div class="fl-add-card">
            <div style="width:42px; height:42px; border-radius:12px; background:var(--green-lt); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <i class="fa-solid fa-utensils" style="color:var(--green-dk); font-size:14px;"></i>
            </div>
            <%= link_to food_path(user_food.food), style: "flex:1; text-decoration:none; min-width:0;" do %>
              <p style="font-size:14px; font-weight:700; color:var(--text); margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= user_food.food.name %></p>
              <p style="font-size:11px; color:var(--sub); margin:2px 0 0; font-weight:600;">
                <%= user_food.food.brand.presence || "No brand" %> &middot;
                <span style="color:var(--green-dk);"><%= user_food.food.calories_per_serving&.round %> kcal/serving</span>
              </p>
            <% end %>
            <div style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
              <%= f.number_field :servings, value: 1, min: 0.5, step: 0.5,
                  class: "fl-servings-input", name: "food_log[servings]" %>
              <%= f.submit "Add", class: "fl-add-btn" %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

</div>
