<div class="pf sm:max-w-md sm:mx-auto">

  <div style="display:flex; align-items:center; gap:12px; margin-bottom:28px;">
    <%= link_to profile_path, class: "fd-back-btn" do %>
      <i class="fa-solid fa-arrow-left" style="color:var(--text); font-size:13px;"></i>
    <% end %>
    <div>
      <h1 style="font-size:20px; font-weight:800; color:var(--text); margin:0;">Set Calorie Goal</h1>
      <p style="font-size:12px; color:var(--sub); margin:2px 0 0; font-weight:600;">You can update this anytime</p>
    </div>
  </div>

  <div style="background:var(--card); border-radius:20px; padding:20px; display:flex; align-items:center; gap:16px; margin-bottom:24px; box-shadow:0 2px 12px var(--shadow);">
    <div style="width:52px; height:52px; border-radius:16px; background:rgba(92,190,59,0.12); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
      <i class="fa-solid fa-flag" style="color:var(--green); font-size:20px;"></i>
    </div>
    <p style="font-size:13px; color:var(--sub); font-weight:600; margin:0; line-height:1.5;">
      Enter your daily calorie target manually, or <strong style="color:var(--text);">take the survey</strong> to let us calculate it for you.
    </p>
  </div>

  <div class="pf-card" style="padding:20px;">
    <%= form_with model: @calorie_profile, url: calorie_profile_path, method: :post do |f| %>
      <%= f.hidden_field :entry_method, value: "manual" %>
      <div style="margin-bottom:24px;">
        <label class="pf-label">
          <i class="fa-solid fa-fire" style="margin-right:4px;"></i> Daily Calorie Target (kcal)
        </label>
        <%= f.number_field :daily_target, class: "pf-input", placeholder: "e.g. 2000" %>
      </div>
      <%= f.submit "Save Goal", class: "pf-btn-primary" %>
    <% end %>
  </div>

  <div style="text-align:center; margin-top:16px;">
    <%= link_to survey_calorie_profile_path, style: "font-size:13px; color:var(--green); font-weight:700; text-decoration:none;" do %>
      <i class="fa-solid fa-calculator" style="font-size:11px;"></i> Calculate with survey instead
    <% end %>
  </div>

</div>
