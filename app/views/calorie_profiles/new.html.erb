<div class="container mx-auto px-4 py-8 max-w-md">
  <h1 class="text-2xl font-bold mb-2">Set Your Calorie Goal</h1>
  <p class="text-gray-500 mb-6">You can update this anytime from your profile.</p>
  <%= form_with model: @calorie_profile, url: calorie_profile_path, method: :post do |f| %>
    <%= f.hidden_field :entry_method, value: "manual" %>
    <div class="mb-4">
      <%= f.label :daily_target, "Daily calorie target (kcal)", class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :daily_target, class: "w-full border rounded px-3 py-2", placeholder: "e.g. 2000" %>
    </div>
    <%= f.submit "Save goal", class: "bg-lime-500 text-white px-4 py-2 rounded hover:bg-lime-600" %>
  <% end %>
</div>
