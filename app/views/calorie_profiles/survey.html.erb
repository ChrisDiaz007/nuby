<div class="container mx-auto px-4 py-8 max-w-md">
  <h1 class="text-2xl font-bold mb-2">Calorie Goal Survey</h1>
  <p class="text-gray-500 mb-6">We'll calculate your daily calorie goal based on your body and lifestyle.</p>
  <%= form_with model: @calorie_profile, url: update_survey_calorie_profile_path, method: :patch do |f| %>
    <div class="mb-4">
      <%= f.label :age, "Age", class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :age, class: "w-full border rounded px-3 py-2", placeholder: "e.g. 25" %>
    </div>
    <div class="mb-4">
      <%= f.label :sex, "Sex", class: "block text-sm font-medium mb-1" %>
      <%= f.select :sex, [["Male", "male"], ["Female", "female"]], { include_blank: "Select..." }, class: "w-full border rounded px-3
  py-2" %>
    </div>
    <div class="mb-4">
      <%= f.label :weight_lbs, "Weight (lbs)", class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :weight_lbs, class: "w-full border rounded px-3 py-2", placeholder: "e.g. 160" %>
    </div>
    <div class="mb-4">
      <%= f.label :height_cm, "Height (cm)", class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :height_cm, class: "w-full border rounded px-3 py-2", placeholder: "e.g. 175" %>
    </div>
    <div class="mb-4">
      <%= f.label :activity_level, "Activity level", class: "block text-sm font-medium mb-1" %>
      <%= f.select :activity_level, [["Sedentary", "sedentary"], ["Lightly active", "lightly_active"], ["Moderately active",
  "moderately_active"], ["Very active", "very_active"]], { include_blank: "Select..." }, class: "w-full border rounded px-3 py-2" %>
    </div>
    <div class="mb-6">
      <%= f.label :goal_type, "Goal", class: "block text-sm font-medium mb-1" %>
      <%= f.select :goal_type, [["Lose weight", "lose"], ["Maintain weight", "maintain"], ["Gain weight", "gain"]], { include_blank:
  "Select..." }, class: "w-full border rounded px-3 py-2" %>
    </div>
    <%= f.submit "Calculate my goal", class: "bg-lime-500 text-white px-4 py-2 rounded hover:bg-lime-600 w-full" %>
  <% end %>
</div>
