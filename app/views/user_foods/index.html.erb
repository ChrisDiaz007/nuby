  
<div class="container mx-auto px-4 py-8 max-w-md">
  <h1 class="text-2xl font-bold mb-6">My Saved Foods</h1>
  <% if @user_foods.empty? %>
    <p class="text-gray-500">You haven't saved any foods yet. <%= link_to "Scan one", scan_foods_path, class: "text-lime-600 underline"
  %></p>
  <% else %>
    <div class="space-y-3">
      <% @user_foods.each do |user_food| %>
        <div class="border rounded-lg p-4 flex justify-between items-center">
          <div>
            <p class="font-semibold"><%= user_food.food.name %></p>
            <p class="text-sm text-gray-500"><%= user_food.food.brand %></p>
            <p class="text-sm"><%= user_food.food.calories_per_100g %> kcal per 100g</p>
          </div>
          <%= button_to "Remove", user_food_path(user_food), method: :delete, class: "text-red-500 text-sm hover:underline", form: {
  data: { turbo_confirm: "Remove this food?" } } %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
